# Auth0
AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=your-auth0-audience
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_ISSUER=https://your-auth0-domain/
CLAIM_NAMESPACE=https://n-athar.co/

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE=your-supabase-service-role-key

# Payments (Moyasar)
MOYASAR_PK=your-moyasar-public-key
MOYASAR_SK=your-moyasar-secret-key
MOYASAR_WEBHOOK_TOKEN=your-moyasar-webhook-token
WEBHOOK_SHARED_SECRET=your-legacy-webhook-shared-secret

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
EMAIL_FROM=team@example.com
FROM_NAME=Athar Team
SUPPORT_EMAIL=support@example.com

# Site URLs
SITE_ORIGIN=https://n-athar.co
SITE_BASE_URL=https://n-athar.co
PUBLIC_BASE_URL=https://n-athar.co
ALLOWED_ORIGIN=https://n-athar.co
WHATSAPP_NUMBER=966500000000

# AI providers
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=your-openai-api-key

# Runtime tuning
TIMEOUT_MS=23000
BACKOFF_MS=700
RETRIES=2
